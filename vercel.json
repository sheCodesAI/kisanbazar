{
    "functions": {
        "kisanbazaar/server.js": {
            "runtime": "@vercel/node"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/kisanbazaar/server.js"
        },
        {
            "source": "/(.*)",
            "destination": "/kisanbazaar/$1"
        }
    ]
}